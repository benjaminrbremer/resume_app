DATABASE_URL=backend/resume_app.db
FILE_DB_ROOT=file_db
VLLM_BASE_URL=http://127.0.0.1:1234
# VLLM_MODEL_NAME: set to the model name shown in LMStudio (e.g. lmstudio-community/Meta-Llama-3-8B-Instruct-GGUF)
VLLM_MODEL_NAME=local-model
# VLLM_EMBED_MODEL_NAME: set to the embedding model loaded in LMStudio (e.g. nomic-ai/nomic-embed-text-v1.5-GGUF)
VLLM_EMBED_MODEL_NAME=nomic-embed-text
